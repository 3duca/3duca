# Configuración del sitio
SITE_NAME="Academia de Robótica e IA"
SITE_URL=http://localhost:8080
SITE_ENV=development

# Base de datos (si se implementa backend)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=academia_robotica
DB_USER=root
DB_PASSWORD=

# Email / Contacto
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=info@academiarobotica.es
SMTP_PASS=
CONTACT_EMAIL=info@academiarobotica.es

# Formulario de inscripción
FORM_RECIPIENT=inscripciones@academiarobotica.es

# Google Services (opcional)
GOOGLE_ANALYTICS_ID=
GOOGLE_MAPS_API_KEY=
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=

# Redes sociales
FACEBOOK_URL=
INSTAGRAM_URL=
TWITTER_URL=
LINKEDIN_URL=
YOUTUBE_URL=

# Configuración de seguridad
SESSION_SECRET=change_this_secret_key_in_production
JWT_SECRET=change_this_jwt_secret
CORS_ORIGIN=http://localhost:8080

# Límites
MAX_UPLOAD_SIZE=5MB
MAX_STUDENTS_PER_CLASS=8

# Pagos (si se implementa)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# Almacenamiento en la nube (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# Modo de mantenimiento
MAINTENANCE_MODE=false
